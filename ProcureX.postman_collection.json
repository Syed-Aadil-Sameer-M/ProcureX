                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  if (Array.isArray(data) && data.length > 0) {",
                  "    pm.collectionVariables.set('purchaseOrderId', data[0].id);",
                  "    pm.test('Purchase order found (ID: ' + data[0].id + ')', function () { pm.expect(data[0].id).to.exist; });",
                  "  } else {",
                  "    pm.test('No purchase orders yet (expected)', function () { pm.expect(true).to.be.true; });",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Update Purchase Order Status (safe to repeat)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SENT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "purchase-orders",
                "{{purchaseOrderId}}",
                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var poId = pm.collectionVariables.get('purchaseOrderId');",
                  "if (!poId) { console.log('purchaseOrderId not set - PUT will use empty ID'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  pm.test('PO status set to: ' + data.status, function () { pm.expect(['CREATED', 'SENT', 'COMPLETED', 'CANCELLED', 'RECEIVED']).to.include(data.status); });",
                  "} else if (pm.response.code === 404) {",
                  "  pm.test('No purchase orders to update (expected)', function () { pm.expect(true).to.be.true; });",
                  "} else {",
                  "  pm.test('Status update may have been idempotent', function () { pm.expect([200, 403, 404, 400]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
