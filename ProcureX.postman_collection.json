  "item": [
    {
      "name": "Setup - Create Seeded Users (Idempotent)",
      "item": [
        {
          "name": "Register Admin User (if not exists)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.test('Admin user registered', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "} else if (pm.response.code === 400) {",
                  "  pm.test('Admin user already exists (expected)', function () { pm.expect(pm.response.text()).to.include('already'); });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Register Receiver User (if not exists)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{receiverUsername}}\",\n  \"email\": \"{{receiverEmail}}\",\n  \"password\": \"{{receiverPassword}}\",\n  \"role\": \"RECEIVER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.test('Receiver user registered', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "} else if (pm.response.code === 400) {",
                  "  pm.test('Receiver user already exists (expected)', function () { pm.expect(pm.response.text()).to.include('already'); });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
