{
  "info": {
    "name": "ProcureX API Collection - Stable & Idempotent",
    "description": "Idempotent collection that maintains stable seeded data. Reuses existing resources, never duplicates. Safe to run multiple times.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminEmail",
      "value": "admin@procurex.test"
    },
    {
      "key": "adminPassword",
      "value": "Admin@123"
    },
    {
      "key": "adminUsername",
      "value": "procurex_admin"
    },
    {
      "key": "receiverEmail",
      "value": "receiver@procurex.test"
    },
    {
      "key": "receiverPassword",
      "value": "Receiver@123"
    },
    {
      "key": "receiverUsername",
      "value": "procurex_receiver"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "inventoryId",
      "value": ""
    },
    {
      "key": "requestId",
      "value": ""
    },
    {
      "key": "notificationId",
      "value": ""
    },
    {
      "key": "vendorId",
      "value": ""
    },
    {
      "key": "purchaseOrderId",
      "value": ""
    },
    {
      "key": "auditLogId",
      "value": ""
